{
  "manifest_version": 3,
  "name": "Tab Auditor Pro",
  "version": "1.0",
  "description": "Sleek tab management with a side panel interface.",
  "permissions": [
    "tabs",
    "sidePanel",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "Open Tab Auditor"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}